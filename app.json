{
  "expo": {
    "name": "Inki",
    "slug": "inki",
    "version": "0.1.0",
    "scheme": "inki",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./src/assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B1B1B"
    },
    "ios": {
      "bundleIdentifier": "com.inki.app",
      "supportsTablet": false
    },
    "android": {
      "package": "com.inki.app",
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-splash-screen",
      "expo-sqlite",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Inki to scan ISBN barcodes and capture quote pages.",
          "recordAudioAndroid": false
        }
      ]
    ]
  }
}
